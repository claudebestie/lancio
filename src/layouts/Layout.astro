---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  extraStructuredData?: string;
}

const {
  title = "Lancio — Votre site lancé en 48h",
  description = "Lancio crée votre site professionnel en 48h à partir de €650. Clé en main, sans rendez-vous, sans surprise. Restaurants, artisans, avocats, médecins, coachs.",
  canonical = "https://lancio.fr",
  ogImage,
  extraStructuredData,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1A3C34" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="fr" href={canonical} />
    <link rel="alternate" hreflang="en" href="https://getmizra.com" />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Geo Meta Tags for Local SEO -->
    <meta name="geo.region" content="FR" />
    <meta name="geo.placename" content="France" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Lancio" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Lancio",
        "description": "Création de site web professionnel en 48h pour TPE et PME",
        "url": "https://lancio.fr",
        "email": "hello@lancio.fr",
        "areaServed": ["FR", "BE", "CH"],
        "priceRange": "€€",
        "serviceType": "Création de site web",
        "knowsLanguage": ["fr", "en", "he"]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Lancio",
        "url": "https://lancio.fr",
        "inLanguage": "fr",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://lancio.fr/?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    {extraStructuredData && <script type="application/ld+json" set:html={extraStructuredData} />}

    <!-- Analytics -->
    <script id="datafast-queue">
      window.datafast = window.datafast || function() {
        window.datafast.q = window.datafast.q || [];
        window.datafast.q.push(arguments);
      };
    </script>
    <script defer data-website-id="dfid_H9G7QTugjA4UgAvUJ2m32" data-domain="lancio.fr" src="https://datafa.st/js/script.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Track page language
        window.datafast?.('page_lang', { lang: 'fr' });

        // Track cta_get_started on all #commander links (covers sector pages too)
        document.querySelectorAll('a[href="#commander"], a[href="/#commander"]').forEach(function(el) {
          el.addEventListener('click', function() {
            window.datafast?.('cta_get_started');
          });
        });

        // Track book_consultation on all Calendly links
        document.querySelectorAll('a[href*="calendly.com"]').forEach(function(el) {
          el.addEventListener('click', function() {
            var page = window.location.pathname.replace(/\//g, '') || 'homepage';
            window.datafast?.('book_consultation', { page: page });
          });
        });

        // Track whatsapp_click on all WhatsApp links
        document.querySelectorAll('a[href*="wa.me"], a[href*="whatsapp"]').forEach(function(el) {
          el.addEventListener('click', function() {
            window.datafast?.('whatsapp_click');
          });
        });
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --font-display: 'DM Serif Display', Georgia, serif;
    --font-body: 'DM Sans', system-ui, sans-serif;

    --black: #0E0E0E;
    --white: #FAFAF8;
    --cream: #F5F3EE;
    --cream-dark: #EAE7DF;
    --accent: #1A3C34;
    --accent-light: #2A5C52;
    --accent-pale: #E8F0EE;
    --text-primary: #0E0E0E;
    --text-secondary: #5A5A55;
    --text-muted: #9A9A92;
    --border: rgba(14,14,14,0.1);
    --border-strong: rgba(14,14,14,0.18);

    --radius-sm: 6px;
    --radius-md: 12px;
    --radius-lg: 20px;
    --radius-xl: 32px;

    --max-w: 1120px;
    --section-py: 100px;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body {
    font-family: var(--font-body);
    color: var(--text-primary);
    background: var(--white);
    line-height: 1.8;
    overflow-x: hidden;
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  .section-pad { padding: var(--section-py) 0; }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  @media (max-width: 768px) {
    :root {
      --section-py: 72px;
    }
    .container {
      padding: 0 20px;
    }
  }
</style>
