---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Création site web thérapeute praticien bien-être — 48h | Lancio"
  description="Lancio crée votre site web pour thérapeute ou praticien bien-être en 48h à partir de €650. Approche, spécialités, prise de RDV. Clé en main."
  canonical="https://lancio.fr/site-web-therapeute/"
  ogImage="https://lancio.fr/secteurs/th%C3%A9rapeutes1.jpg"
  extraStructuredData={JSON.stringify([
    {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Lancio","item":"https://lancio.fr/"},
      {"@type":"ListItem","position":2,"name":"Site web thérapeute","item":"https://lancio.fr/site-web-therapeute/"}
    ]},
    {"@context":"https://schema.org","@type":"Service","serviceType":"Création de site web pour thérapeute",
     "provider":{"@type":"ProfessionalService","name":"Lancio","url":"https://lancio.fr"},
     "areaServed":{"@type":"Country","name":"France"},
     "offers":{"@type":"Offer","price":"650","priceCurrency":"EUR"}}
  ])}
>
  <Nav />
  <main class="secteur-page">
    <section class="secteur-hero">
      <div class="container">
        <div class="breadcrumb"><a href="/">Lancio</a><span>→</span><span>Site web thérapeute</span></div>
        <h1>Création site web<br/><em>thérapeute</em> en 48h</h1>
        <p class="secteur-sub">Votre approche, vos spécialités, prise de rendez-vous — un site rassurant qui inspire confiance. Livré en 48h à partir de €650.</p>
        <div class="secteur-actions">
          <a href="/#commander" class="btn-primary">Commander mon site thérapeute →</a>
          <div class="secteur-proof"><span>⭐ 4.9/5</span><span>·</span><span>47 sites livrés</span><span>·</span><span>48h garantis</span></div>
        </div>
      </div>
    </section>

    <section class="secteur-galerie section-pad">
      <div class="container">
        <h2>Exemples de sites thérapeute</h2>
        <div class="examples-grid">
          <a href="/examples/therapeute/" class="example-card">
            <img class="ex-preview" src="/secteurs/thérapeutes1.jpg" alt="Exemple de site thérapeute créé par Lancio" loading="lazy" />
            <div class="ex-body">
              <h3>Cabinet Sérénité — Site thérapeute</h3>
              <p>Approche, spécialités, prise de RDV</p>
            </div>
          </a>
          <a href="/#commander" class="example-card example-cta-card">
            <div>
              <h3>Vous voulez un site comme celui-ci ?</h3>
              <p>Commandez le vôtre — livraison 48h</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="secteur-inclus section-pad">
      <div class="container">
        <h2>Un site qui inspire confiance</h2>
        <div class="inclus-grid">
          <div class="inclus-card"><div class="inclus-icon">🌿</div><h3>Votre approche</h3><p>Expliquez votre méthode, votre parcours, votre philosophie — pour que le patient se sente en confiance avant même de vous contacter.</p></div>
          <div class="inclus-card"><div class="inclus-icon">🧠</div><h3>Spécialités</h3><p>Stress, deuil, trauma, développement personnel — vos domaines d'expertise clairement présentés.</p></div>
          <div class="inclus-card"><div class="inclus-icon">📅</div><h3>Prise de RDV</h3><p>Formulaire de contact discret ou lien Doctolib/Calendly — selon votre mode de fonctionnement.</p></div>
          <div class="inclus-card"><div class="inclus-icon">💬</div><h3>Témoignages</h3><p>Retours de patients (anonymisés) qui rassurent les nouveaux visiteurs.</p></div>
          <div class="inclus-card"><div class="inclus-icon">🔍</div><h3>SEO local</h3><p>Apparaître sur "thérapeute [votre ville]" ou "psychologue [quartier]" — attirez de nouveaux patients.</p></div>
          <div class="inclus-card"><div class="inclus-icon">📱</div><h3>Design apaisant & mobile</h3><p>Un site calme et professionnel, en accord avec votre pratique. Parfait sur tous les écrans.</p></div>
        </div>
      </div>
    </section>

    <section class="secteur-cta section-pad" style="background: var(--cream);">
      <div class="container cta-inner">
        <h2>Facilitez le premier pas de vos futurs patients.</h2>
        <p>Commandez aujourd'hui — votre site est en ligne dans 48h.</p>
        <a href="/#commander" class="btn-primary">Je lance mon site →</a>
        <div class="cta-price">À partir de €650 · Livraison 48h garantie · Satisfait ou on recommence</div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .secteur-hero { padding: 120px 0 80px; background: var(--cream); border-bottom: 1px solid var(--border); }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-muted); margin-bottom: 24px; }
  .breadcrumb a { color: var(--accent); }
  h1 { font-size: clamp(36px, 5vw, 64px); margin-bottom: 20px; line-height: 1.05; }
  h1 em { font-style: italic; color: var(--accent); }
  .secteur-sub { font-size: 18px; color: var(--text-secondary); max-width: 560px; line-height: 1.65; margin-bottom: 32px; }
  .secteur-actions { display: flex; flex-direction: column; gap: 16px; }
  .secteur-proof { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text-muted); }
  .btn-primary { display: inline-flex; font-size: 15px; font-weight: 500; background: var(--accent); color: var(--white); padding: 14px 28px; border-radius: var(--radius-md); transition: background 0.15s, transform 0.1s; width: fit-content; }
  .btn-primary:hover { background: var(--accent-light); transform: translateY(-2px); }
  .section-pad { padding: var(--section-py) 0; }
  h2 { font-size: clamp(28px, 3.5vw, 40px); margin-bottom: 40px; text-align: center; line-height: 1.1; }
  .examples-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .example-card { display: block; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; text-decoration: none; color: inherit; transition: transform 0.3s, box-shadow 0.3s; }
  .example-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
  .ex-preview { width: 100%; height: 180px; object-fit: cover; }
  .ex-body { padding: 16px; }
  .ex-body h3 { font-family: var(--font-body); font-size: 15px; font-weight: 500; color: var(--text-primary); margin: 0 0 4px; }
  .ex-body p { font-size: 13px; color: var(--text-secondary); margin: 0; }
  .example-cta-card { display: flex; align-items: center; justify-content: center; min-height: 180px; background: var(--accent-pale); border: 1px dashed var(--accent); text-align: center; padding: 24px; }
  .example-cta-card h3 { color: var(--accent); }
  .inclus-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .inclus-card { background: var(--cream); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; }
  .inclus-icon { font-size: 24px; margin-bottom: 12px; }
  .inclus-card h3 { font-family: var(--font-body); font-size: 15px; font-weight: 500; margin-bottom: 8px; }
  .inclus-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }
  .cta-inner { text-align: center; }
  .cta-inner p { font-size: 16px; color: var(--text-secondary); margin-bottom: 28px; }
  .cta-inner h2 { margin-bottom: 12px; }
  .cta-price { margin-top: 16px; font-size: 13px; color: var(--text-muted); }
  @media (max-width: 768px) { .inclus-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .inclus-grid { grid-template-columns: 1fr; } }
</style>
