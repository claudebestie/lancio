>
  <Nav />
  <main>
    <Hero />
    <Secteurs />
    <Problem />
    <Exemples />
    <Process />
    <Pricing />
    <AuditGratuit />
    <Temoignages />
    <FAQ />
    <Commander />
    <Contact />
