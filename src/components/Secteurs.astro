---
const secteurs = [
  { icon: "🍽️", label: "Restaurant", href: "/site-web-restaurant/" },
  { icon: "✂️", label: "Coiffeur", href: "/site-web-coiffeur/" },
  { icon: "⚖️", label: "Avocat", href: "/site-web-avocat/" },
  { icon: "🩺", label: "Médecin", href: "/site-web-medecin/" },
  { icon: "🏋️", label: "Coach sportif", href: "/site-web-coach-sportif/" },
  { icon: "💅", label: "Salon de beauté", href: "/site-web-salon-de-beaute/" },
  { icon: "☕", label: "Café", href: "/site-web-cafe/" },
  { icon: "🧘", label: "Pilates", href: "/site-web-pilates/" },
  { icon: "🌿", label: "Thérapeute", href: "/site-web-therapeute/" },
  { icon: "🏠", label: "Immobilier", href: "/site-web-immobilier/" },
  { icon: "🔧", label: "Artisan", href: "/site-web-artisan/" },
];
---

<div class="secteurs-wrap">
  <div class="secteurs-label">Pour tous les professionnels</div>
  <div class="secteurs-track">
    <div class="secteurs-inner">
      {secteurs.map(s => (
        <a href={s.href} class="secteur-item">
          <span class="secteur-icon">{s.icon}</span>
          <span class="secteur-name">{s.label}</span>
        </a>
      ))}
      {secteurs.map(s => (
        <a href={s.href} class="secteur-item" aria-hidden="true">
          <span class="secteur-icon">{s.icon}</span>
          <span class="secteur-name">{s.label}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .secteurs-wrap {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
    overflow: hidden;
  }
  .secteurs-label {
    text-align: center;
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }
  .secteurs-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .secteurs-inner {
    display: flex;
    gap: 12px;
    animation: scroll 28s linear infinite;
    width: max-content;
  }
  .secteurs-inner:hover { animation-play-state: paused; }
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .secteur-item {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 8px 16px;
    white-space: nowrap;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s, border-color 0.15s;
  }
  .secteur-item:hover {
    background: var(--accent-pale);
    border-color: var(--accent);
  }
  .secteur-icon { font-size: 15px; }
  .secteur-name { font-size: 13px; color: var(--text-secondary); font-weight: 400; }
</style>
