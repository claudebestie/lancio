---
// Commander.astro — Lancio
// Flow : Brief → Supabase → redirect vers Stripe Payment Link
---
<section class="commander section-pad" id="commander">
  <div class="container">
    <div class="commander-inner">
      <div class="commander-left">
        <div class="section-tag">Commander</div>
        <h2 class="section-h2">Votre site en ligne<br/><em>avant la fin de la semaine.</em></h2>
        <p class="commander-sub">
          Remplissez le brief en 5 minutes. On s'occupe du reste. Votre site est en ligne dans 48h.
        </p>
        <div class="commander-reassurance">
          <div class="reassure-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="var(--accent-pale)"/><path d="M5 8l2 2 4-4" stroke="var(--accent)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Paiement sécurisé Stripe
          </div>
          <div class="reassure-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="var(--accent-pale)"/><path d="M5 8l2 2 4-4" stroke="var(--accent)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Livraison 48h garantie
          </div>
          <div class="reassure-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="var(--accent-pale)"/><path d="M5 8l2 2 4-4" stroke="var(--accent)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Satisfait ou on recommence
          </div>
        </div>

        <!-- Stripe Payment Links — à créer dans dashboard.stripe.com -->
        <div class="payment-links">
          <div class="pl-label">Paiement direct sans brief →</div>
          <div class="pl-links">
            <a href="https://buy.stripe.com/6oU14nfrP9cj64cd6D4Ja00" class="pl-link" target="_blank">
              Site de base — €650
            </a>
            <a href="https://buy.stripe.com/6oUcN57Znagn3W4c2z4Ja02" class="pl-link" target="_blank">
              + SEO local — €800
            </a>
            <a href="https://buy.stripe.com/7sY9AT3J774b64c5Eb4Ja03" class="pl-link pl-featured" target="_blank">
              Site complet (base + SEO + RDV) — €900
            </a>
          </div>
          <div class="pl-note">Paiement en 1 clic · Carte ou virement</div>
        </div>
      </div>

      <div class="brief-form">
        <div class="form-header">
          <span class="form-title">Brief de commande</span>
          <span class="form-duration">~ 5 min</span>
        </div>

        <!-- Étape 1 : Brief -->
        <div id="step-brief" class="form-body">
          <div class="field-group">
            <label class="field-label">Votre prénom et nom *</label>
            <input type="text" id="f-nom" placeholder="Marie Dupont" required />
          </div>

          <div class="field-row">
            <div class="field-group">
              <label class="field-label">Email *</label>
              <input type="email" id="f-email" placeholder="marie@restaurant.fr" required />
            </div>
            <div class="field-group">
              <label class="field-label">Téléphone</label>
              <input type="tel" id="f-tel" placeholder="+33 6 XX XX XX XX" />
            </div>
          </div>

          <div class="field-group">
            <label class="field-label">Votre secteur *</label>
            <select id="f-secteur" required>
              <option value="">Choisissez votre secteur</option>
              <option>Restaurant / Café</option>
              <option>Salon de coiffure / Barbier</option>
              <option>Cabinet médical / Médecin</option>
              <option>Avocat / Cabinet juridique</option>
              <option>Coach sportif / Personnel</option>
              <option>Artisan / Plombier / Électricien</option>
              <option>Thérapeute / Psychologue</option>
              <option>Agent immobilier</option>
              <option>Photographe / Créatif</option>
              <option>Autre profession libérale</option>
            </select>
          </div>

          <div class="field-group">
            <label class="field-label">Nom de votre entreprise *</label>
            <input type="text" id="f-entreprise" placeholder="Ex: Restaurant Le Midi" required />
          </div>

          <div class="field-group">
            <label class="field-label">Nom de domaine existant ?</label>
            <input type="text" id="f-domaine" placeholder="monrestaurant.fr (laissez vide sinon)" />
          </div>

          <div class="field-group">
            <label class="field-label">Décrivez votre activité *</label>
            <textarea id="f-description" rows="3" placeholder="Qui êtes-vous ? Quels services ? Quelle ville ?" required></textarea>
          </div>

          <div class="field-group">
            <label class="field-label">Options souhaitées</label>
            <div class="options-grid">
              <label class="option-check">
                <input type="checkbox" class="f-option" value="seo-local" data-price="150" />
                <span>SEO local +€150</span>
              </label>
              <label class="option-check">
                <input type="checkbox" class="f-option" value="rdv-en-ligne" data-price="100" />
                <span>RDV en ligne +€100</span>
              </label>
              <label class="option-check">
                <input type="checkbox" class="f-option" value="blog" data-price="200" />
                <span>Blog SEO +€200</span>
              </label>
              <label class="option-check option-maintenance">
                <input type="checkbox" id="f-maintenance" value="maintenance" data-price="0" />
                <span>Maintenance mensuelle — 50€/mois</span>
              </label>
              <label class="option-check">
                <input type="checkbox" class="f-option" value="boutique" data-price="350" />
                <span>Boutique en ligne +€350</span>
              </label>
            </div>
          </div>

          <div class="price-summary" id="priceSummary">
            <span class="price-label">Total estimé (paiement unique)</span>
            <span class="price-val" id="priceVal">€650</span>
          </div>
          <div id="maintenanceNote" class="maintenance-note" style="display:none;">
            + Maintenance 50€/mois <span class="maint-detail">· facturée mensuellement après livraison</span>
          </div>

          <div id="form-error" style="display:none; font-size:13px; color:#A32D2D; padding:10px; background:#FEF0F0; border-radius:8px;"></div>

          <button type="button" class="form-submit" id="submitBtn" onclick="submitBrief()">
            Envoyer mon brief et payer →
          </button>

          <div class="form-note">
            Après validation, vous serez redirigé vers le paiement sécurisé Stripe.
          </div>
        </div>

        <!-- Étape 2 : Paiement Stripe -->
        <div id="step-payment" style="display:none;" class="form-body">
          <div class="payment-step">
            <div class="payment-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="20" fill="var(--accent-pale)"/><path d="M12 20l6 6 12-12" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="payment-title">Brief reçu !</div>
            <div class="payment-sub">Dernière étape : le paiement sécurisé pour confirmer votre commande.</div>
            <div class="payment-amount" id="paymentAmount">€650</div>
            <a id="stripeBtn" href="#" class="stripe-cta" target="_blank">
              Payer maintenant via Stripe →
            </a>
            <div class="payment-secure">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1L2 2.5v3.5c0 3.3 1.8 4.5 4 5 2.2-.5 4-1.7 4-5V2.5L6 1z" fill="var(--accent)" opacity=".3" stroke="var(--accent)" stroke-width=".8"/></svg>
              Paiement 100% sécurisé — Stripe · Carte ou virement
            </div>

            <!-- Abonnement maintenance (affiché seulement si coché) -->
            <div id="maintenancePayment" class="maintenance-payment" style="display:none;">
              <div class="maintenance-divider"></div>
              <div class="maintenance-payment-title">Maintenance mensuelle</div>
              <div class="maintenance-payment-price">50€<span>/mois</span></div>
              <div class="maintenance-payment-desc">Mises à jour, modifications de contenu et support prioritaire. Résiliable à tout moment.</div>
              <a id="maintenanceStripeBtn" href="#" class="maintenance-cta" target="_blank">
                S'abonner à la maintenance →
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .commander-inner {
    display: grid;
    grid-template-columns: 1fr 540px;
    gap: 64px;
    align-items: start;
  }
  .commander-sub { font-size: 16px; color: var(--text-secondary); line-height: 1.65; margin: 20px 0 28px; }
  .commander-reassurance { display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }
  .reassure-item { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--text-secondary); }

  /* Payment Links rapides */
  .payment-links { margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--border); }
  .pl-label { font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }
  .pl-links { display: flex; flex-direction: column; gap: 8px; }
  .pl-link {
    font-size: 13px; color: var(--accent); font-weight: 500;
    padding: 9px 14px; border: 1px solid rgba(26,60,52,0.2);
    border-radius: var(--radius-md); transition: background .15s;
    display: flex; align-items: center; justify-content: space-between;
  }
  .pl-link:hover { background: var(--accent-pale); }
  .pl-link.pl-featured { background: var(--accent); color: var(--white); border-color: var(--accent); }
  .pl-link.pl-featured:hover { background: var(--accent-light); }
  .pl-link::after { content: '→'; }
  .pl-note { font-size: 11px; color: var(--text-muted); margin-top: 8px; }

  /* Form */
  .brief-form { background: var(--white); border: 1px solid var(--border-strong); border-radius: var(--radius-xl); overflow: hidden; }
  .form-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 28px; border-bottom: 1px solid var(--border); background: var(--cream); }
  .form-title { font-size: 15px; font-weight: 500; }
  .form-duration { font-size: 12px; color: var(--text-muted); background: var(--white); padding: 3px 10px; border-radius: 100px; border: 1px solid var(--border); }
  .form-body { padding: 28px; display: flex; flex-direction: column; gap: 18px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .field-group { display: flex; flex-direction: column; gap: 6px; }
  .field-label { font-size: 12px; font-weight: 500; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .05em; }
  input, select, textarea {
    font-family: var(--font-body); font-size: 14px; color: var(--text-primary);
    background: var(--white); border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm); padding: 10px 14px; width: 100%;
    transition: border-color .15s; outline: none; appearance: none;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,60,52,0.08); }
  textarea { resize: vertical; min-height: 80px; }
  select { background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%235A5A55' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 14px center; padding-right: 36px; cursor: pointer; }
  .options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .option-check { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px; color: var(--text-secondary); padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); transition: all .15s; }
  .option-check:hover { border-color: var(--accent); background: var(--accent-pale); }
  .option-check input { width: auto; padding: 0; border: none; box-shadow: none; }

  /* Price summary */
  .price-summary { display: flex; justify-content: space-between; align-items: center; background: var(--accent-pale); border: 1px solid rgba(26,60,52,0.15); border-radius: var(--radius-md); padding: 12px 16px; }
  .price-label { font-size: 13px; color: var(--accent); font-weight: 500; }
  .price-val { font-size: 22px; font-weight: 500; color: var(--accent); }

  .form-submit { font-family: var(--font-body); font-size: 15px; font-weight: 500; background: var(--accent); color: var(--white); border: none; border-radius: var(--radius-md); padding: 16px 24px; cursor: pointer; transition: background .15s, transform .1s; width: 100%; text-align: center; }
  .form-submit:hover { background: var(--accent-light); transform: translateY(-1px); }
  .form-submit:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .form-note { font-size: 12px; color: var(--text-muted); text-align: center; line-height: 1.5; }

  /* Payment step */
  .payment-step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; padding: 20px 0; }
  .payment-title { font-size: 20px; font-weight: 500; color: var(--text-primary); }
  .payment-sub { font-size: 14px; color: var(--text-secondary); max-width: 300px; line-height: 1.6; }
  .payment-amount { font-family: var(--font-display); font-size: 48px; color: var(--accent); }
  .stripe-cta { display: block; background: var(--accent); color: var(--white); font-size: 15px; font-weight: 500; padding: 16px 32px; border-radius: var(--radius-md); transition: background .15s, transform .1s; width: 100%; text-align: center; }
  .stripe-cta:hover { background: var(--accent-light); transform: translateY(-2px); }
  .payment-secure { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-muted); }

  /* Maintenance note */
  .maintenance-note {
    font-size: 13px; color: var(--accent); font-weight: 500;
    padding: 8px 16px; background: var(--accent-pale);
    border-radius: var(--radius-sm); text-align: right;
  }
  .maintenance-note .maint-detail { font-weight: 400; color: var(--text-muted); font-size: 12px; }
  .option-maintenance span { font-weight: 500; }

  /* Maintenance payment step */
  .maintenance-payment { margin-top: 16px; text-align: center; }
  .maintenance-divider { height: 1px; background: var(--border); margin: 16px 0; }
  .maintenance-payment-title { font-size: 14px; font-weight: 500; color: var(--text-primary); }
  .maintenance-payment-price { font-family: var(--font-display); font-size: 28px; color: var(--accent); margin: 4px 0; }
  .maintenance-payment-price span { font-size: 14px; font-weight: 400; color: var(--text-muted); }
  .maintenance-payment-desc { font-size: 12px; color: var(--text-secondary); max-width: 280px; margin: 0 auto 12px; line-height: 1.5; }
  .maintenance-cta {
    display: block; background: var(--cream); color: var(--accent);
    font-size: 13px; font-weight: 500; padding: 12px 24px;
    border: 1px solid var(--accent); border-radius: var(--radius-md);
    transition: background .15s, transform .1s; width: 100%; text-align: center;
  }
  .maintenance-cta:hover { background: var(--accent-pale); transform: translateY(-1px); }

  @media (max-width: 960px) { .commander-inner { grid-template-columns: 1fr; gap: 40px; } }
  @media (max-width: 480px) { .field-row { grid-template-columns: 1fr; } .options-grid { grid-template-columns: 1fr; } .form-body { padding: 20px; } }
</style>

<script>
  // ── Config ────────────────────────────────────────────────────────────────────
  const SUPABASE_URL = 'https://rofkgmwjggvxlgrdnsyt.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJvZmtnbXdqZ2d2eGxncmRuc3l0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE5MzA2MTgsImV4cCI6MjA4NzUwNjYxOH0.6nlnX-0wUlID-630j5fOyveEAG0Lrp2gWhgGMRKpmNk';

  // ── Stripe Payment Links (one-time) ─────────────────────────────────────────
  const STRIPE_LINKS: Record<number, string> = {
    650:  'https://buy.stripe.com/6oU14nfrP9cj64cd6D4Ja00',  // Base
    750:  'https://buy.stripe.com/cNi14ndjH60778g5Eb4Ja04',  // Base + RDV
    800:  'https://buy.stripe.com/6oUcN57Znagn3W4c2z4Ja02',  // Base + SEO
    850:  'https://buy.stripe.com/00w00jenLbkrdwEc2z4Ja01',  // Base + Blog
    900:  'https://buy.stripe.com/7sY9AT3J774b64c5Eb4Ja03',  // Base + SEO + RDV
    950:  'https://buy.stripe.com/aFa6oHa7vfAHaks2rZ4Ja0f',  // Base + RDV + Blog
    1000: 'https://buy.stripe.com/dRm5kDfrPagneAI3w34Ja0e',  // Base + Boutique
    1050: 'https://buy.stripe.com/7sY6oHgvT74bdwE0jR4Ja0d',  // Base + SEO + Blog
    1100: 'https://buy.stripe.com/fZu4gzcfD4W3dwE0jR4Ja0c',  // Base + RDV + Boutique  OU  Base + SEO + RDV + Blog
    1150: 'https://buy.stripe.com/3cIbJ10wV2NVfEMgiP4Ja0a',  // Base + SEO + Boutique
    1200: 'https://buy.stripe.com/14A5kD0wVcoveAIaYv4Ja09',  // Base + Blog + Boutique
    1250: 'https://buy.stripe.com/6oU5kDgvT88fcsA7Mj4Ja08',  // Base + SEO + RDV + Boutique
    1300: 'https://buy.stripe.com/4gM4gz7Zn0FN64c0jR4Ja07',  // Base + RDV + Blog + Boutique
    1350: 'https://buy.stripe.com/6oU14n2F39cjgIQ1nV4Ja06',  // Base + SEO + Blog + Boutique
    1450: 'https://buy.stripe.com/4gM28rcfD607eAI4A74Ja0g',  // Base + SEO + RDV + Blog + Boutique
  };

  // ── Stripe Subscription Link pour la maintenance (50€/mois) ─────────────────
  const STRIPE_MAINTENANCE_LINK = 'https://buy.stripe.com/5kQcN593r9cj1NW3w34Ja05';

  // ── Add-on prices (one-time uniquement, maintenance = abonnement séparé) ────
  const ADDON_PRICES: Record<string, number> = {
    'seo-local': 150,
    'rdv-en-ligne': 100,
    'blog': 200,
    'boutique': 350,
  };

  // ── Update price display ───────────────────────────────────────────────────────
  function updatePrice() {
    let total = 650;
    document.querySelectorAll<HTMLInputElement>('.f-option:checked').forEach(cb => {
      total += ADDON_PRICES[cb.value] || 0;
    });
    const el = document.getElementById('priceVal');
    if (el) el.textContent = '€' + total.toLocaleString('fr-FR');

    // Afficher la note maintenance si cochée
    const maintenanceCb = document.getElementById('f-maintenance') as HTMLInputElement;
    const maintenanceNote = document.getElementById('maintenanceNote');
    if (maintenanceNote) {
      maintenanceNote.style.display = maintenanceCb?.checked ? 'block' : 'none';
    }
    return total;
  }

  document.querySelectorAll('.f-option').forEach(cb => {
    cb.addEventListener('change', updatePrice);
  });
  document.getElementById('f-maintenance')?.addEventListener('change', updatePrice);

  // ── Submit brief ──────────────────────────────────────────────────────────────
  async function submitBrief() {
    const btn = document.getElementById('submitBtn') as HTMLButtonElement;
    const errorDiv = document.getElementById('form-error') as HTMLDivElement;
    errorDiv.style.display = 'none';

    // Validation
    const nom = (document.getElementById('f-nom') as HTMLInputElement).value.trim();
    const email = (document.getElementById('f-email') as HTMLInputElement).value.trim();
    const secteur = (document.getElementById('f-secteur') as HTMLSelectElement).value;
    const entreprise = (document.getElementById('f-entreprise') as HTMLInputElement).value.trim();
    const description = (document.getElementById('f-description') as HTMLTextAreaElement).value.trim();

    if (!nom || !email || !secteur || !entreprise || !description) {
      errorDiv.textContent = 'Merci de remplir tous les champs obligatoires.';
      errorDiv.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Envoi en cours…';

    const checkedOptions: string[] = [];
    let optionsTotal = 0;
    document.querySelectorAll<HTMLInputElement>('.f-option:checked').forEach(cb => {
      checkedOptions.push(cb.value);
      optionsTotal += ADDON_PRICES[cb.value] || 0;
    });

    // Maintenance = abonnement séparé, pas dans le total one-time
    const maintenanceCb = document.getElementById('f-maintenance') as HTMLInputElement;
    const wantsMaintenance = maintenanceCb?.checked || false;
    if (wantsMaintenance && !checkedOptions.includes('maintenance')) {
      checkedOptions.push('maintenance');
    }

    const totalPrice = 650 + optionsTotal;

    // ── FIX BUG CRITIQUE : bloquer si pas de lien Stripe au lieu de fallback €650
    const stripeLink = STRIPE_LINKS[totalPrice];
    if (!stripeLink || stripeLink.startsWith('TODO')) {
      errorDiv.textContent = 'Cette combinaison d\'options n\'est pas encore disponible au paiement en ligne. Contactez-nous à hello@lancio.fr pour finaliser votre commande.';
      errorDiv.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Envoyer mon brief et payer →';
      return;
    }

    const payload = {
      nom, email,
      tel: (document.getElementById('f-tel') as HTMLInputElement).value.trim() || null,
      secteur, entreprise,
      domaine: (document.getElementById('f-domaine') as HTMLInputElement).value.trim() || null,
      description,
      options: checkedOptions.length > 0 ? checkedOptions : null,
      options_total: optionsTotal,
      base_price: 650,
      total_price: totalPrice,
      maintenance: wantsMaintenance,
      maintenance_price_monthly: wantsMaintenance ? 50 : 0,
      status: 'new',
      source: 'lancio.fr',
    };

    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/lancio_orders`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${SUPABASE_KEY}`,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        throw new Error('Supabase error');
      }

      // Afficher étape paiement
      const stepBrief = document.getElementById('step-brief') as HTMLElement;
      const stepPayment = document.getElementById('step-payment') as HTMLElement;
      stepBrief.style.display = 'none';
      stepPayment.style.display = 'block';

      const amountEl = document.getElementById('paymentAmount') as HTMLElement;
      amountEl.textContent = '€' + totalPrice.toLocaleString('fr-FR');

      const stripeBtn = document.getElementById('stripeBtn') as HTMLAnchorElement;
      stripeBtn.href = `${stripeLink}?prefilled_email=${encodeURIComponent(email)}&client_reference_id=${encodeURIComponent(entreprise)}`;

      // Si maintenance cochée → afficher le lien d'abonnement séparé
      const maintenancePayment = document.getElementById('maintenancePayment') as HTMLElement;
      const maintenanceStripeBtn = document.getElementById('maintenanceStripeBtn') as HTMLAnchorElement;
      if (wantsMaintenance && maintenancePayment && maintenanceStripeBtn) {
        maintenancePayment.style.display = 'block';
        maintenanceStripeBtn.href = `${STRIPE_MAINTENANCE_LINK}?prefilled_email=${encodeURIComponent(email)}&client_reference_id=${encodeURIComponent(entreprise)}`;
      }

    } catch (err) {
      console.error(err);
      errorDiv.textContent = 'Erreur. Écrivez-nous directement à hello@lancio.fr';
      errorDiv.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Envoyer mon brief et payer →';
    }
  }

  // Exposer pour onclick
  (window as any).submitBrief = submitBrief;
</script>
