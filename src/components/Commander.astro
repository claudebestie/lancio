---
// Commander.astro — Lancio
// Flow : Brief → Supabase → redirect vers Stripe Payment Link
---
<section class="commander section-pad" id="commander">
  <div class="container">
    <div class="commander-inner">
      <div class="commander-left">
        <div class="section-tag">Commander</div>
        <h2 class="section-h2">Votre site en ligne<br/><em>avant la fin de la semaine.</em></h2>
        <p class="commander-sub">
          Remplissez le brief en 5 minutes. On s'occupe du reste. Votre site est en ligne dans 48h.
        </p>
        <div class="commander-reassurance">
          <div class="reassure-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="var(--accent-pale)"/><path d="M5 8l2 2 4-4" stroke="var(--accent)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Paiement sécurisé Stripe
          </div>
          <div class="reassure-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="var(--accent-pale)"/><path d="M5 8l2 2 4-4" stroke="var(--accent)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Livraison 48h garantie
          </div>
          <div class="reassure-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="var(--accent-pale)"/><path d="M5 8l2 2 4-4" stroke="var(--accent)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Satisfait ou on recommence
          </div>
        </div>

        <!-- Menu tarifs clair -->
        <div class="menu-tarifs">
          <div class="menu-tarifs-title">Ce que vous obtenez</div>
          <div class="menu-base">
            <div class="menu-base-header">
              <div class="menu-base-name">Site vitrine professionnel</div>
              <div class="menu-base-price">€650</div>
            </div>
            <div class="menu-base-desc">3 à 5 pages sur-mesure, responsive mobile, formulaire de contact, hébergement + domaine 1 an, certificat SSL, livraison 48h.</div>
          </div>
          <div class="menu-options-title">Options à ajouter</div>
          <div class="menu-options">
            <div class="menu-option">
              <div class="menu-option-left">
                <div class="menu-option-name">SEO local</div>
                <div class="menu-option-desc">Fiche Google Business, balises optimisées, référencement local pour apparaître dans les résultats de votre ville.</div>
              </div>
              <div class="menu-option-price">+€150</div>
            </div>
            <div class="menu-option">
              <div class="menu-option-left">
                <div class="menu-option-name">Prise de RDV en ligne</div>
                <div class="menu-option-desc">Calendrier intégré (Calendly ou Cal.com) pour que vos clients réservent directement depuis votre site.</div>
              </div>
              <div class="menu-option-price">+€100</div>
            </div>
            <div class="menu-option">
              <div class="menu-option-left">
                <div class="menu-option-name">Blog SEO (5 articles)</div>
                <div class="menu-option-desc">5 articles optimisés pour le référencement, rédigés et publiés sur votre site pour attirer du trafic organique.</div>
              </div>
              <div class="menu-option-price">+€200</div>
            </div>
            <div class="menu-option">
              <div class="menu-option-left">
                <div class="menu-option-name">Boutique en ligne</div>
                <div class="menu-option-desc">Catalogue produits, panier d'achat et paiement sécurisé intégré directement à votre site.</div>
              </div>
              <div class="menu-option-price">+€350</div>
            </div>
            <div class="menu-option">
              <div class="menu-option-left">
                <div class="menu-option-name">Page supplémentaire</div>
                <div class="menu-option-desc">Ajoutez une page additionnelle à votre site (portfolio, équipe, FAQ, etc.).</div>
              </div>
              <div class="menu-option-price">+€80</div>
            </div>
            <div class="menu-option menu-option-recurring">
              <div class="menu-option-left">
                <div class="menu-option-name">Maintenance mensuelle</div>
                <div class="menu-option-desc">Mises à jour de contenu, modifications mineures et support prioritaire. Résiliable à tout moment.</div>
              </div>
              <div class="menu-option-price">50€<span>/mois</span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="brief-form">
        <div class="form-header">
          <span class="form-title">Brief de commande</span>
          <span class="form-duration">~ 5 min</span>
        </div>

        <!-- Étape 1 : Brief -->
        <div id="step-brief" class="form-body">
          <div class="field-group">
            <label class="field-label">Votre prénom et nom *</label>
            <input type="text" id="f-nom" placeholder="Marie Dupont" required />
          </div>

          <div class="field-row">
            <div class="field-group">
              <label class="field-label">Email *</label>
              <input type="email" id="f-email" placeholder="marie@restaurant.fr" required />
            </div>
            <div class="field-group">
              <label class="field-label">Téléphone</label>
              <input type="tel" id="f-tel" placeholder="+33 6 XX XX XX XX" />
            </div>
          </div>

          <div class="field-group">
            <label class="field-label">Votre secteur *</label>
            <select id="f-secteur" required>
              <option value="">Choisissez votre secteur</option>
              <option>Restaurant / Café</option>
              <option>Salon de coiffure / Barbier</option>
              <option>Cabinet médical / Médecin</option>
              <option>Avocat / Cabinet juridique</option>
              <option>Coach sportif / Personnel</option>
              <option>Artisan / Plombier / Électricien</option>
              <option>Thérapeute / Psychologue</option>
              <option>Agent immobilier</option>
              <option>Photographe / Créatif</option>
              <option>Autre profession libérale</option>
            </select>
          </div>

          <div class="field-group">
            <label class="field-label">Nom de votre entreprise *</label>
            <input type="text" id="f-entreprise" placeholder="Ex: Restaurant Le Midi" required />
          </div>

          <div class="field-group">
            <label class="field-label">Nom de domaine existant ?</label>
            <input type="text" id="f-domaine" placeholder="monrestaurant.fr (laissez vide sinon)" />
          </div>

          <div class="field-group">
            <label class="field-label">Décrivez votre activité *</label>
            <textarea id="f-description" rows="3" placeholder="Qui êtes-vous ? Quels services ? Quelle ville ?" required></textarea>
          </div>

          <div class="field-group">
            <label class="field-label">Options souhaitées</label>
            <div class="options-grid">
              <label class="option-check">
                <input type="checkbox" class="f-option" value="seo-local" data-price="150" />
                <span>SEO local +€150</span>
              </label>
              <label class="option-check">
                <input type="checkbox" class="f-option" value="rdv-en-ligne" data-price="100" />
                <span>RDV en ligne +€100</span>
              </label>
              <label class="option-check">
                <input type="checkbox" class="f-option" value="blog" data-price="200" />
                <span>Blog SEO +€200</span>
              </label>
              <label class="option-check option-maintenance">
                <input type="checkbox" id="f-maintenance" value="maintenance" data-price="0" />
                <span>Maintenance mensuelle — 50€/mois</span>
              </label>
              <label class="option-check">
                <input type="checkbox" class="f-option" value="boutique" data-price="350" />
                <span>Boutique en ligne +€350</span>
              </label>
            </div>
          </div>

          <div class="price-summary" id="priceSummary">
            <span class="price-label">Total estimé (paiement unique)</span>
            <span class="price-val" id="priceVal">€650</span>
          </div>
          <div id="maintenanceNote" class="maintenance-note" style="display:none;">
            + Maintenance 50€/mois <span class="maint-detail">· facturée mensuellement après livraison</span>
          </div>

          <div id="form-error" style="display:none; font-size:13px; color:#A32D2D; padding:10px; background:#FEF0F0; border-radius:8px;"></div>

          <button type="button" class="form-submit" id="submitBtn" onclick="showRecap()">
            Voir le récapitulatif →
          </button>

          <div class="form-note">
            Vous pourrez relire votre commande avant de payer.
          </div>
        </div>

        <!-- Étape 2 : Récapitulatif -->
        <div id="step-recap" style="display:none;" class="form-body">
          <div class="recap-step">
            <div class="recap-header-title">Récapitulatif de votre commande</div>
            <div class="recap-subtitle">Vérifiez vos informations avant de confirmer.</div>

            <div class="recap-card">
              <div class="recap-section">
                <div class="recap-section-title">Vos coordonnées</div>
                <div class="recap-row"><span class="recap-label">Nom</span><span class="recap-value" id="recap-nom"></span></div>
                <div class="recap-row"><span class="recap-label">Email</span><span class="recap-value" id="recap-email"></span></div>
                <div class="recap-row" id="recap-tel-row" style="display:none;"><span class="recap-label">Téléphone</span><span class="recap-value" id="recap-tel"></span></div>
              </div>

              <div class="recap-divider"></div>

              <div class="recap-section">
                <div class="recap-section-title">Votre projet</div>
                <div class="recap-row"><span class="recap-label">Secteur</span><span class="recap-value" id="recap-secteur"></span></div>
                <div class="recap-row"><span class="recap-label">Entreprise</span><span class="recap-value" id="recap-entreprise"></span></div>
                <div class="recap-row" id="recap-domaine-row" style="display:none;"><span class="recap-label">Domaine</span><span class="recap-value" id="recap-domaine"></span></div>
                <div class="recap-row recap-row-full"><span class="recap-label">Description</span><span class="recap-value recap-value-desc" id="recap-description"></span></div>
              </div>

              <div class="recap-divider"></div>

              <div class="recap-section">
                <div class="recap-section-title">Formule & options</div>
                <div class="recap-row"><span class="recap-label">Site de base</span><span class="recap-price">€650</span></div>
                <div id="recap-options-list"></div>
                <div id="recap-maintenance-row" class="recap-row" style="display:none;"><span class="recap-label">Maintenance mensuelle</span><span class="recap-price recap-price-muted">50€/mois</span></div>
              </div>

              <div class="recap-total">
                <span class="recap-total-label">Total (paiement unique)</span>
                <span class="recap-total-val" id="recap-total"></span>
              </div>
              <div id="recap-maintenance-note" class="recap-maintenance-note" style="display:none;">
                + Maintenance 50€/mois · facturée après livraison
              </div>
            </div>

            <div id="recap-error" style="display:none; font-size:13px; color:#A32D2D; padding:10px; background:#FEF0F0; border-radius:8px;"></div>

            <button type="button" class="form-submit" id="confirmBtn" onclick="confirmAndPay()">
              Confirmer et payer →
            </button>
            <button type="button" class="recap-back" onclick="backToForm()">
              ← Modifier mon brief
            </button>
          </div>
        </div>

        <!-- Étape 3 : Paiement Stripe -->
        <div id="step-payment" style="display:none;" class="form-body">
          <div class="payment-step">
            <div class="payment-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="20" fill="var(--accent-pale)"/><path d="M12 20l6 6 12-12" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="payment-title">Brief reçu !</div>
            <div class="payment-sub">Dernière étape : le paiement sécurisé pour confirmer votre commande.</div>
            <div class="payment-amount" id="paymentAmount">€650</div>
            <a id="stripeBtn" href="#" class="stripe-cta" onclick="handleStripeClick()">
              Payer maintenant via Stripe →
            </a>
            <div class="payment-secure">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1L2 2.5v3.5c0 3.3 1.8 4.5 4 5 2.2-.5 4-1.7 4-5V2.5L6 1z" fill="var(--accent)" opacity=".3" stroke="var(--accent)" stroke-width=".8"/></svg>
              Paiement 100% sécurisé — Stripe · Carte ou virement
            </div>

            <!-- Abonnement maintenance (affiché seulement si coché) -->
            <div id="maintenancePayment" class="maintenance-payment" style="display:none;">
              <div class="maintenance-divider"></div>
              <div class="maintenance-payment-title">Maintenance mensuelle</div>
              <div class="maintenance-payment-price">50€<span>/mois</span></div>
              <div class="maintenance-payment-desc">Mises à jour, modifications de contenu et support prioritaire. Résiliable à tout moment.</div>
              <a id="maintenanceStripeBtn" href="#" class="maintenance-cta" target="_blank">
                S'abonner à la maintenance →
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .commander-inner {
    display: grid;
    grid-template-columns: 1fr 540px;
    gap: 64px;
    align-items: start;
  }
  .commander-sub { font-size: 16px; color: var(--text-secondary); line-height: 1.8; margin: 20px 0 28px; }
  .commander-reassurance { display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }
  .reassure-item { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--text-secondary); }

  /* Menu tarifs */
  .menu-tarifs { margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--border); }
  .menu-tarifs-title { font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 14px; }
  .menu-base { background: var(--accent-pale); border: 1.5px solid var(--accent); border-radius: var(--radius-md); padding: 16px 18px; margin-bottom: 20px; }
  .menu-base-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
  .menu-base-name { font-size: 15px; font-weight: 500; color: var(--accent); }
  .menu-base-price { font-family: var(--font-display); font-size: 28px; color: var(--accent); }
  .menu-base-desc { font-size: 12px; color: var(--text-secondary); line-height: 1.6; }
  .menu-options-title { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 10px; }
  .menu-options { display: flex; flex-direction: column; gap: 0; }
  .menu-option { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .menu-option:last-child { border-bottom: none; }
  .menu-option-left { flex: 1; }
  .menu-option-name { font-size: 13px; font-weight: 500; color: var(--text-primary); margin-bottom: 2px; }
  .menu-option-desc { font-size: 11px; color: var(--text-muted); line-height: 1.5; }
  .menu-option-price { font-size: 14px; font-weight: 500; color: var(--accent); white-space: nowrap; flex-shrink: 0; padding-top: 1px; }
  .menu-option-price span { font-size: 11px; font-weight: 400; color: var(--text-muted); }
  .menu-option-recurring { background: var(--cream); margin: 0 -18px; padding: 12px 18px; border-bottom: none; border-radius: 0 0 var(--radius-sm) var(--radius-sm); }

  /* Form */
  .brief-form { background: var(--white); border: 1px solid var(--border-strong); border-radius: var(--radius-xl); overflow: hidden; }
  .form-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 28px; border-bottom: 1px solid var(--border); background: var(--cream); }
  .form-title { font-size: 15px; font-weight: 500; }
  .form-duration { font-size: 12px; color: var(--text-muted); background: var(--white); padding: 3px 10px; border-radius: 100px; border: 1px solid var(--border); }
  .form-body { padding: 28px; display: flex; flex-direction: column; gap: 18px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .field-group { display: flex; flex-direction: column; gap: 6px; }
  .field-label { font-size: 12px; font-weight: 500; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .05em; }
  input, select, textarea {
    font-family: var(--font-body); font-size: 14px; color: var(--text-primary);
    background: var(--white); border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm); padding: 10px 14px; width: 100%;
    transition: border-color .15s; outline: none; appearance: none;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,60,52,0.08); }
  textarea { resize: vertical; min-height: 80px; }
  select { background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%235A5A55' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 14px center; padding-right: 36px; cursor: pointer; }
  .options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .option-check { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px; color: var(--text-secondary); padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); transition: all .15s; }
  .option-check:hover { border-color: var(--accent); background: var(--accent-pale); }
  .option-check input { width: auto; padding: 0; border: none; box-shadow: none; }

  /* Price summary */
  .price-summary { display: flex; justify-content: space-between; align-items: center; background: var(--accent-pale); border: 1px solid rgba(26,60,52,0.15); border-radius: var(--radius-md); padding: 12px 16px; }
  .price-label { font-size: 13px; color: var(--accent); font-weight: 500; }
  .price-val { font-size: 22px; font-weight: 500; color: var(--accent); }

  .form-submit { font-family: var(--font-body); font-size: 15px; font-weight: 500; background: var(--accent); color: var(--white); border: none; border-radius: var(--radius-md); padding: 16px 24px; cursor: pointer; transition: background .15s, transform .1s; width: 100%; text-align: center; }
  .form-submit:hover { background: var(--accent-light); transform: translateY(-1px); }
  .form-submit:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .form-note { font-size: 12px; color: var(--text-muted); text-align: center; line-height: 1.5; }

  /* Payment step */
  .payment-step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; padding: 20px 0; }
  .payment-title { font-size: 20px; font-weight: 500; color: var(--text-primary); }
  .payment-sub { font-size: 14px; color: var(--text-secondary); max-width: 300px; line-height: 1.6; }
  .payment-amount { font-family: var(--font-display); font-size: 48px; color: var(--accent); }
  .stripe-cta { display: block; background: var(--accent); color: var(--white); font-size: 15px; font-weight: 500; padding: 16px 32px; border-radius: var(--radius-md); transition: background .15s, transform .1s; width: 100%; text-align: center; }
  .stripe-cta:hover { background: var(--accent-light); transform: translateY(-2px); }
  .payment-secure { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-muted); }

  /* Maintenance note */
  .maintenance-note {
    font-size: 13px; color: var(--accent); font-weight: 500;
    padding: 8px 16px; background: var(--accent-pale);
    border-radius: var(--radius-sm); text-align: right;
  }
  .maintenance-note .maint-detail { font-weight: 400; color: var(--text-muted); font-size: 12px; }
  .option-maintenance span { font-weight: 500; }

  /* Maintenance payment step */
  .maintenance-payment { margin-top: 16px; text-align: center; }
  .maintenance-divider { height: 1px; background: var(--border); margin: 16px 0; }
  .maintenance-payment-title { font-size: 14px; font-weight: 500; color: var(--text-primary); }
  .maintenance-payment-price { font-family: var(--font-display); font-size: 28px; color: var(--accent); margin: 4px 0; }
  .maintenance-payment-price span { font-size: 14px; font-weight: 400; color: var(--text-muted); }
  .maintenance-payment-desc { font-size: 12px; color: var(--text-secondary); max-width: 280px; margin: 0 auto 12px; line-height: 1.5; }
  .maintenance-cta {
    display: block; background: var(--cream); color: var(--accent);
    font-size: 13px; font-weight: 500; padding: 12px 24px;
    border: 1px solid var(--accent); border-radius: var(--radius-md);
    transition: background .15s, transform .1s; width: 100%; text-align: center;
  }
  .maintenance-cta:hover { background: var(--accent-pale); transform: translateY(-1px); }

  /* Recap step */
  .recap-step { display: flex; flex-direction: column; gap: 16px; }
  .recap-header-title { font-family: var(--font-display); font-size: 22px; color: var(--text-primary); text-align: center; }
  .recap-subtitle { font-size: 14px; color: var(--text-secondary); text-align: center; margin-bottom: 4px; }
  .recap-card { background: var(--cream); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; display: flex; flex-direction: column; gap: 0; }
  .recap-section { display: flex; flex-direction: column; gap: 8px; padding: 16px 0; }
  .recap-section:first-child { padding-top: 0; }
  .recap-section-title { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: .08em; color: var(--text-muted); margin-bottom: 4px; }
  .recap-divider { height: 1px; background: var(--border); }
  .recap-row { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .recap-row-full { flex-direction: column; gap: 4px; }
  .recap-label { font-size: 13px; color: var(--text-secondary); flex-shrink: 0; }
  .recap-value { font-size: 13px; color: var(--text-primary); font-weight: 500; text-align: right; }
  .recap-value-desc { font-weight: 400; text-align: left; font-size: 13px; line-height: 1.6; color: var(--text-secondary); }
  .recap-price { font-size: 13px; color: var(--accent); font-weight: 500; }
  .recap-price-muted { color: var(--text-muted); font-weight: 400; }
  .recap-total { display: flex; justify-content: space-between; align-items: center; padding: 16px 0 0; border-top: 1px solid var(--border-strong); margin-top: 8px; }
  .recap-total-label { font-size: 14px; font-weight: 500; color: var(--text-primary); }
  .recap-total-val { font-size: 28px; font-family: var(--font-display); color: var(--accent); }
  .recap-maintenance-note { font-size: 12px; color: var(--accent); text-align: right; margin-top: -8px; }
  .recap-back {
    font-family: var(--font-body); font-size: 14px; color: var(--text-secondary);
    background: none; border: none; cursor: pointer; text-align: center;
    text-decoration: underline; text-underline-offset: 3px;
    transition: color .15s; padding: 4px;
  }
  .recap-back:hover { color: var(--text-primary); }

  @media (max-width: 960px) { .commander-inner { grid-template-columns: 1fr; gap: 40px; } }
  @media (max-width: 480px) { .field-row { grid-template-columns: 1fr; } .options-grid { grid-template-columns: 1fr; } .form-body { padding: 20px; } .recap-card { padding: 16px; } }
</style>

<script>
  // ── Config ────────────────────────────────────────────────────────────────────
  const SUPABASE_URL = 'https://rofkgmwjggvxlgrdnsyt.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJvZmtnbXdqZ2d2eGxncmRuc3l0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE5MzA2MTgsImV4cCI6MjA4NzUwNjYxOH0.6nlnX-0wUlID-630j5fOyveEAG0Lrp2gWhgGMRKpmNk';

  // ── Stripe Payment Links (one-time) ─────────────────────────────────────────
  const STRIPE_LINKS: Record<number, string> = {
    650:  'https://buy.stripe.com/6oU14nfrP9cj64cd6D4Ja00',  // Base
    750:  'https://buy.stripe.com/cNi14ndjH60778g5Eb4Ja04',  // Base + RDV
    800:  'https://buy.stripe.com/6oUcN57Znagn3W4c2z4Ja02',  // Base + SEO
    850:  'https://buy.stripe.com/00w00jenLbkrdwEc2z4Ja01',  // Base + Blog
    900:  'https://buy.stripe.com/7sY9AT3J774b64c5Eb4Ja03',  // Base + SEO + RDV
    950:  'https://buy.stripe.com/aFa6oHa7vfAHaks2rZ4Ja0f',  // Base + RDV + Blog
    1000: 'https://buy.stripe.com/dRm5kDfrPagneAI3w34Ja0e',  // Base + Boutique
    1050: 'https://buy.stripe.com/7sY6oHgvT74bdwE0jR4Ja0d',  // Base + SEO + Blog
    1100: 'https://buy.stripe.com/fZu4gzcfD4W3dwE0jR4Ja0c',  // Base + RDV + Boutique  OU  Base + SEO + RDV + Blog
    1150: 'https://buy.stripe.com/3cIbJ10wV2NVfEMgiP4Ja0a',  // Base + SEO + Boutique
    1200: 'https://buy.stripe.com/14A5kD0wVcoveAIaYv4Ja09',  // Base + Blog + Boutique
    1250: 'https://buy.stripe.com/6oU5kDgvT88fcsA7Mj4Ja08',  // Base + SEO + RDV + Boutique
    1300: 'https://buy.stripe.com/4gM4gz7Zn0FN64c0jR4Ja07',  // Base + RDV + Blog + Boutique
    1350: 'https://buy.stripe.com/6oU14n2F39cjgIQ1nV4Ja06',  // Base + SEO + Blog + Boutique
    1450: 'https://buy.stripe.com/4gM28rcfD607eAI4A74Ja0g',  // Base + SEO + RDV + Blog + Boutique
  };

  // ── Stripe Subscription Link pour la maintenance (50€/mois) ─────────────────
  const STRIPE_MAINTENANCE_LINK = 'https://buy.stripe.com/5kQcN593r9cj1NW3w34Ja05';

  // ── Add-on prices (one-time uniquement, maintenance = abonnement séparé) ────
  const ADDON_PRICES: Record<string, number> = {
    'seo-local': 150,
    'rdv-en-ligne': 100,
    'blog': 200,
    'boutique': 350,
  };

  // ── Update price display ───────────────────────────────────────────────────────
  function updatePrice() {
    let total = 650;
    document.querySelectorAll<HTMLInputElement>('.f-option:checked').forEach(cb => {
      total += ADDON_PRICES[cb.value] || 0;
    });
    const el = document.getElementById('priceVal');
    if (el) el.textContent = '€' + total.toLocaleString('fr-FR');

    // Afficher la note maintenance si cochée
    const maintenanceCb = document.getElementById('f-maintenance') as HTMLInputElement;
    const maintenanceNote = document.getElementById('maintenanceNote');
    if (maintenanceNote) {
      maintenanceNote.style.display = maintenanceCb?.checked ? 'block' : 'none';
    }
    return total;
  }

  document.querySelectorAll('.f-option').forEach(cb => {
    cb.addEventListener('change', updatePrice);
  });
  document.getElementById('f-maintenance')?.addEventListener('change', updatePrice);

  // ── Option labels for recap ──────────────────────────────────────────────────
  const OPTION_LABELS: Record<string, string> = {
    'seo-local': 'SEO local',
    'rdv-en-ligne': 'RDV en ligne',
    'blog': 'Blog SEO (5 articles)',
    'boutique': 'Boutique en ligne',
  };

  // ── Show Recap (étape intermédiaire) ──────────────────────────────────────────
  function showRecap() {
    const errorDiv = document.getElementById('form-error') as HTMLDivElement;
    errorDiv.style.display = 'none';

    // Validation
    const nom = (document.getElementById('f-nom') as HTMLInputElement).value.trim();
    const email = (document.getElementById('f-email') as HTMLInputElement).value.trim();
    const secteur = (document.getElementById('f-secteur') as HTMLSelectElement).value;
    const entreprise = (document.getElementById('f-entreprise') as HTMLInputElement).value.trim();
    const description = (document.getElementById('f-description') as HTMLTextAreaElement).value.trim();

    if (!nom || !email || !secteur || !entreprise || !description) {
      errorDiv.textContent = 'Merci de remplir tous les champs obligatoires.';
      errorDiv.style.display = 'block';
      return;
    }

    const tel = (document.getElementById('f-tel') as HTMLInputElement).value.trim();
    const domaine = (document.getElementById('f-domaine') as HTMLInputElement).value.trim();

    // Remplir le recap
    (document.getElementById('recap-nom') as HTMLElement).textContent = nom;
    (document.getElementById('recap-email') as HTMLElement).textContent = email;

    const telRow = document.getElementById('recap-tel-row') as HTMLElement;
    if (tel) {
      (document.getElementById('recap-tel') as HTMLElement).textContent = tel;
      telRow.style.display = 'flex';
    } else {
      telRow.style.display = 'none';
    }

    (document.getElementById('recap-secteur') as HTMLElement).textContent = secteur;
    (document.getElementById('recap-entreprise') as HTMLElement).textContent = entreprise;

    const domaineRow = document.getElementById('recap-domaine-row') as HTMLElement;
    if (domaine) {
      (document.getElementById('recap-domaine') as HTMLElement).textContent = domaine;
      domaineRow.style.display = 'flex';
    } else {
      domaineRow.style.display = 'none';
    }

    (document.getElementById('recap-description') as HTMLElement).textContent = description;

    // Options
    const optionsList = document.getElementById('recap-options-list') as HTMLElement;
    optionsList.innerHTML = '';
    let optionsTotal = 0;
    document.querySelectorAll<HTMLInputElement>('.f-option:checked').forEach(cb => {
      const price = ADDON_PRICES[cb.value] || 0;
      optionsTotal += price;
      const row = document.createElement('div');
      row.style.cssText = 'display:flex;justify-content:space-between;align-items:baseline;gap:12px';
      row.innerHTML = `<span style="font-size:13px;color:var(--text-secondary)">${OPTION_LABELS[cb.value] || cb.value}</span><span style="font-size:13px;color:var(--accent);font-weight:500">+€${price}</span>`;
      optionsList.appendChild(row);
    });

    const totalPrice = 650 + optionsTotal;
    (document.getElementById('recap-total') as HTMLElement).textContent = '€' + totalPrice.toLocaleString('fr-FR');

    // Maintenance
    const maintenanceCb = document.getElementById('f-maintenance') as HTMLInputElement;
    const wantsMaintenance = maintenanceCb?.checked || false;
    const maintenanceRow = document.getElementById('recap-maintenance-row') as HTMLElement;
    const maintenanceNote = document.getElementById('recap-maintenance-note') as HTMLElement;
    maintenanceRow.style.display = wantsMaintenance ? 'flex' : 'none';
    maintenanceNote.style.display = wantsMaintenance ? 'block' : 'none';

    // Vérifier que le lien Stripe existe
    const stripeLink = STRIPE_LINKS[totalPrice];
    if (!stripeLink || stripeLink.startsWith('TODO')) {
      const recapError = document.getElementById('recap-error') as HTMLDivElement;
      recapError.textContent = 'Cette combinaison d\'options n\'est pas encore disponible au paiement en ligne. Contactez-nous à hello@lancio.fr.';
      recapError.style.display = 'block';
    }

    // Basculer les étapes
    (document.getElementById('step-brief') as HTMLElement).style.display = 'none';
    (document.getElementById('step-recap') as HTMLElement).style.display = 'block';

    // Scroll vers le haut du formulaire
    document.querySelector('.brief-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Back to form ──────────────────────────────────────────────────────────────
  function backToForm() {
    (document.getElementById('step-recap') as HTMLElement).style.display = 'none';
    (document.getElementById('step-brief') as HTMLElement).style.display = 'flex';
    document.querySelector('.brief-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Confirm & Pay (anciennement submitBrief) ──────────────────────────────────
  async function confirmAndPay() {
    const btn = document.getElementById('confirmBtn') as HTMLButtonElement;
    const errorDiv = document.getElementById('recap-error') as HTMLDivElement;
    errorDiv.style.display = 'none';

    btn.disabled = true;
    btn.textContent = 'Envoi en cours…';

    const nom = (document.getElementById('f-nom') as HTMLInputElement).value.trim();
    const email = (document.getElementById('f-email') as HTMLInputElement).value.trim();
    const secteur = (document.getElementById('f-secteur') as HTMLSelectElement).value;
    const entreprise = (document.getElementById('f-entreprise') as HTMLInputElement).value.trim();
    const description = (document.getElementById('f-description') as HTMLTextAreaElement).value.trim();

    const checkedOptions: string[] = [];
    let optionsTotal = 0;
    document.querySelectorAll<HTMLInputElement>('.f-option:checked').forEach(cb => {
      checkedOptions.push(cb.value);
      optionsTotal += ADDON_PRICES[cb.value] || 0;
    });

    const maintenanceCb = document.getElementById('f-maintenance') as HTMLInputElement;
    const wantsMaintenance = maintenanceCb?.checked || false;
    if (wantsMaintenance && !checkedOptions.includes('maintenance')) {
      checkedOptions.push('maintenance');
    }

    const totalPrice = 650 + optionsTotal;

    const stripeLink = STRIPE_LINKS[totalPrice];
    if (!stripeLink || stripeLink.startsWith('TODO')) {
      errorDiv.textContent = 'Cette combinaison d\'options n\'est pas encore disponible au paiement en ligne. Contactez-nous à hello@lancio.fr pour finaliser votre commande.';
      errorDiv.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Confirmer et payer →';
      return;
    }

    const payload = {
      nom, email,
      tel: (document.getElementById('f-tel') as HTMLInputElement).value.trim() || null,
      secteur, entreprise,
      domaine: (document.getElementById('f-domaine') as HTMLInputElement).value.trim() || null,
      description,
      options: checkedOptions.length > 0 ? checkedOptions : null,
      options_total: optionsTotal,
      base_price: 650,
      total_price: totalPrice,
      maintenance: wantsMaintenance,
      maintenance_price_monthly: wantsMaintenance ? 50 : 0,
      status: 'new',
      source: 'lancio.fr',
    };

    try {
      // ── 1. Créer la commande dans lancio_orders ──
      const res = await fetch(`${SUPABASE_URL}/rest/v1/lancio_orders`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${SUPABASE_KEY}`,
          'Prefer': 'return=representation',
        },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error('Supabase error');

      // ── 2. Auto-créer le lancio_onboarding lié ──
      try {
        const [order] = await res.json();
        const onbPayload = {
          order_id: order?.id || null,
          nom, email,
          tel: (document.getElementById('f-tel') as HTMLInputElement).value.trim() || null,
          secteur, entreprise,
          domaine: (document.getElementById('f-domaine') as HTMLInputElement).value.trim() || null,
          description,
          status: 'pending', seen: false, done: false, source: 'lancio.fr',
        };
        await fetch(`${SUPABASE_URL}/rest/v1/lancio_onboarding`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`, 'Prefer': 'return=minimal' },
          body: JSON.stringify(onbPayload),
        });
      } catch (onbErr) { console.warn('Onboarding auto-creation failed (non-blocking):', onbErr); }

      // Datafast: track order_submitted + thank_you_view
      const selectedOptions = checkedOptions.filter(o => o !== 'maintenance').join(', ') || 'base';
      window.datafast?.('order_submitted', { package: selectedOptions, total: '€' + totalPrice, method: 'stripe' });
      window.datafast?.('thank_you_view', { type: 'order' });

      // Afficher étape paiement
      (document.getElementById('step-recap') as HTMLElement).style.display = 'none';
      (document.getElementById('step-payment') as HTMLElement).style.display = 'block';

      (document.getElementById('paymentAmount') as HTMLElement).textContent = '€' + totalPrice.toLocaleString('fr-FR');
      (document.getElementById('stripeBtn') as HTMLAnchorElement).href = `${stripeLink}?prefilled_email=${encodeURIComponent(email)}&client_reference_id=${encodeURIComponent(entreprise)}`;

      // Si maintenance cochée → afficher le lien d'abonnement séparé
      const maintenancePayment = document.getElementById('maintenancePayment') as HTMLElement;
      const maintenanceStripeBtn = document.getElementById('maintenanceStripeBtn') as HTMLAnchorElement;
      if (wantsMaintenance && maintenancePayment && maintenanceStripeBtn) {
        maintenancePayment.style.display = 'block';
        maintenanceStripeBtn.href = `${STRIPE_MAINTENANCE_LINK}?prefilled_email=${encodeURIComponent(email)}&client_reference_id=${encodeURIComponent(entreprise)}`;
      }

      document.querySelector('.brief-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });

    } catch (err) {
      console.error(err);
      errorDiv.textContent = 'Erreur. Écrivez-nous directement à hello@lancio.fr';
      errorDiv.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Confirmer et payer →';
    }
  }

  // ── Handle Stripe click: open payment in new tab, redirect to /merci/ ──────
  function handleStripeClick() {
    const btn = document.getElementById('stripeBtn') as HTMLAnchorElement;
    const href = btn.href;
    if (href && href !== '#') {
      window.open(href, '_blank');
      window.datafast?.('payment_success');
      // Redirect to thank you page after short delay
      setTimeout(() => {
        window.location.href = '/merci/';
      }, 1500);
    }
  }
  (window as any).handleStripeClick = handleStripeClick;

  // ── Datafast: track open_order_modal when #commander becomes visible ────────
  const commanderSection = document.getElementById('commander');
  if (commanderSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          window.datafast?.('open_order_modal');
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });
    observer.observe(commanderSection);
  }

  // Exposer pour onclick
  (window as any).showRecap = showRecap;
  (window as any).backToForm = backToForm;
  (window as any).confirmAndPay = confirmAndPay;
</script>
