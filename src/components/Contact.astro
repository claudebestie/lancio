---
// Contact.astro — Lancio
// Formulaire de contact → lancio_messages (Supabase)
---
<section class="contact section-pad" id="contact">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-left">
        <div class="section-tag">Contact</div>
        <h2 class="section-h2">Une question ?<br/><em>On vous répond vite.</em></h2>
        <p class="contact-sub">
          Besoin d'un renseignement avant de commander ? Écrivez-nous, on répond sous 24h.
        </p>
        <div class="contact-direct">
          <a href="mailto:hello@lancio.fr" class="contact-email-link">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="3" width="14" height="10" rx="2" stroke="var(--accent)" stroke-width="1.3"/><path d="M1 5l7 4 7-4" stroke="var(--accent)" stroke-width="1.3" stroke-linejoin="round"/></svg>
            hello@lancio.fr
          </a>
          <a href="https://calendly.com/hello-beyitworld/30min" target="_blank" class="contact-calendly-link">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="2.5" width="13" height="12" rx="2" stroke="var(--accent)" stroke-width="1.3"/><path d="M1.5 6.5h13" stroke="var(--accent)" stroke-width="1.3"/><path d="M5 1v3M11 1v3" stroke="var(--accent)" stroke-width="1.3" stroke-linecap="round"/></svg>
            Prendre RDV avec un conseiller →
          </a>
        </div>
      </div>

      <div class="contact-form">
        <div class="form-header">
          <span class="form-title">Nous écrire</span>
        </div>
        <div class="form-body" id="contact-form-body">
          <div class="field-row">
            <div class="field-group">
              <label class="field-label">Votre nom *</label>
              <input type="text" id="c-nom" placeholder="Marie Dupont" required />
            </div>
            <div class="field-group">
              <label class="field-label">Email *</label>
              <input type="email" id="c-email" placeholder="marie@exemple.fr" required />
            </div>
          </div>

          <div class="field-group">
            <label class="field-label">Téléphone</label>
            <input type="tel" id="c-tel" placeholder="+33 6 XX XX XX XX" />
          </div>

          <div class="field-group">
            <label class="field-label">Votre message *</label>
            <textarea id="c-message" rows="4" placeholder="Décrivez votre besoin, posez vos questions..." required></textarea>
          </div>

          <div id="c-error" style="display:none; font-size:13px; color:#A32D2D; padding:10px; background:#FEF0F0; border-radius:8px;"></div>

          <button type="button" class="form-submit" id="c-submit" onclick="submitContact()">
            Envoyer mon message →
          </button>
        </div>

        <div id="contact-success" class="form-body" style="display:none;">
          <div class="success-step">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="20" fill="var(--accent-pale)"/><path d="M12 20l6 6 12-12" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div class="success-title">Message envoyé !</div>
            <div class="success-sub">Merci pour votre message. On vous répond sous 24h maximum.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 64px;
    align-items: start;
  }
  .contact-sub { font-size: 16px; color: var(--text-secondary); line-height: 1.8; margin: 20px 0 24px; }
  .contact-direct { display: flex; flex-direction: column; gap: 12px; }
  .contact-email-link, .contact-calendly-link {
    display: flex; align-items: center; gap: 10px;
    font-size: 15px; color: var(--accent); font-weight: 500;
    text-decoration: underline; text-underline-offset: 3px;
  }
  .contact-calendly-link {
    background: var(--accent-pale);
    border: 1px solid rgba(26,60,52,0.15);
    border-radius: var(--radius-md);
    padding: 10px 16px;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }
  .contact-calendly-link:hover { background: var(--accent); color: var(--white); transform: translateY(-1px); }
  .contact-calendly-link:hover svg path, .contact-calendly-link:hover svg rect { stroke: var(--white); }
  .contact-form { background: var(--white); border: 1px solid var(--border-strong); border-radius: var(--radius-xl); overflow: hidden; }
  .form-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 28px; border-bottom: 1px solid var(--border); background: var(--cream); }
  .form-title { font-size: 15px; font-weight: 500; }
  .form-body { padding: 28px; display: flex; flex-direction: column; gap: 18px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .field-group { display: flex; flex-direction: column; gap: 6px; }
  .field-label { font-size: 12px; font-weight: 500; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .05em; }
  .contact-form input, .contact-form textarea {
    font-family: var(--font-body); font-size: 14px; color: var(--text-primary);
    background: var(--white); border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm); padding: 10px 14px; width: 100%;
    transition: border-color .15s; outline: none; appearance: none;
  }
  .contact-form input:focus, .contact-form textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,60,52,0.08); }
  .contact-form textarea { resize: vertical; min-height: 80px; }
  .form-submit {
    font-family: var(--font-body); font-size: 15px; font-weight: 500;
    background: var(--accent); color: var(--white); border: none;
    border-radius: var(--radius-md); padding: 16px 24px; cursor: pointer;
    transition: background .15s, transform .1s; width: 100%; text-align: center;
  }
  .form-submit:hover { background: var(--accent-light); transform: translateY(-1px); }
  .form-submit:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .success-step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; padding: 40px 0; }
  .success-title { font-size: 20px; font-weight: 500; color: var(--text-primary); }
  .success-sub { font-size: 14px; color: var(--text-secondary); max-width: 300px; line-height: 1.6; }
  @media (max-width: 960px) { .contact-inner { grid-template-columns: 1fr; gap: 40px; } }
  @media (max-width: 480px) { .field-row { grid-template-columns: 1fr; } .form-body { padding: 20px; } }
</style>

<script>
  const SUPABASE_URL = 'https://rofkgmwjggvxlgrdnsyt.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJvZmtnbXdqZ2d2eGxncmRuc3l0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE5MzA2MTgsImV4cCI6MjA4NzUwNjYxOH0.6nlnX-0wUlID-630j5fOyveEAG0Lrp2gWhgGMRKpmNk';

  async function submitContact() {
    const btn = document.getElementById('c-submit') as HTMLButtonElement;
    const errorDiv = document.getElementById('c-error') as HTMLDivElement;
    errorDiv.style.display = 'none';

    const nom = (document.getElementById('c-nom') as HTMLInputElement).value.trim();
    const email = (document.getElementById('c-email') as HTMLInputElement).value.trim();
    const tel = (document.getElementById('c-tel') as HTMLInputElement).value.trim();
    const message = (document.getElementById('c-message') as HTMLTextAreaElement).value.trim();

    if (!nom || !email || !message) {
      errorDiv.textContent = 'Merci de remplir les champs obligatoires (nom, email, message).';
      errorDiv.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';

    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/lancio_messages`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${SUPABASE_KEY}`,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({
          nom,
          email,
          tel: tel || null,
          message,
          seen: false,
          done: false,
          source: 'lancio.fr',
        }),
      });

      if (!res.ok) throw new Error('Erreur Supabase');

      (document.getElementById('contact-form-body') as HTMLElement).style.display = 'none';
      (document.getElementById('contact-success') as HTMLElement).style.display = 'block';

    } catch (err) {
      console.error(err);
      errorDiv.textContent = 'Erreur d\'envoi. Écrivez-nous directement à hello@lancio.fr';
      errorDiv.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Envoyer mon message →';
    }
  }

  (window as any).submitContact = submitContact;
</script>
