---
const exemples = [
  {
    secteur: "Restaurant",
    ville: "Paris",
    titre: "La Table du Chef",
    desc: "Site bilingue avec menu en ligne, réservation et photos",
    color: "#D4C9B5",
    accent: "#8B6F47",
  },
  {
    secteur: "Salon de coiffure",
    ville: "Lyon",
    titre: "Studio Éclat",
    desc: "Prise de rendez-vous en ligne, galerie avant/après",
    color: "#C5D4D0",
    accent: "#2A5C52",
  },
  {
    secteur: "Cabinet avocat",
    ville: "Marseille",
    titre: "Maître Fontaine",
    desc: "Site institutionnel, formulaire de contact, blog juridique",
    color: "#D0CDE0",
    accent: "#3C3489",
  },
  {
    secteur: "Coach sportif",
    ville: "Bordeaux",
    titre: "Marc Performance",
    desc: "Landing page avec programme, témoignages, CTA fort",
    color: "#D4E0D0",
    accent: "#1A3C34",
  },
  {
    secteur: "Artisan plombier",
    ville: "Toulouse",
    titre: "Durand Plomberie",
    desc: "Site vitrine urgences 24h/7j, devis en ligne",
    color: "#E0D8CE",
    accent: "#5A4A3A",
  },
  {
    secteur: "Médecin",
    ville: "Nantes",
    titre: "Dr. Legrand",
    desc: "Présentation cabinet, horaires, prise de RDV Doctolib",
    color: "#D0DDE8",
    accent: "#185FA5",
  },
];
---

<section class="exemples section-pad" id="exemples">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">Exemples</div>
      <h2 class="section-h2">Des sites livrés en 48h,<br/><em>pour des pros comme vous</em></h2>
      <p class="section-sub">Chaque site est créé sur mesure — pas de template générique.</p>
    </div>

    <div class="exemples-grid">
      {exemples.map(e => (
        <div class="exemple-card">
          <div class="exemple-preview" style={`background: ${e.color};`}>
            <div class="preview-nav" style={`background: rgba(255,255,255,0.7);`}>
              <div class="preview-logo" style={`background: ${e.accent}; opacity:0.3;`}></div>
              <div class="preview-links">
                <div class="preview-link"></div>
                <div class="preview-link"></div>
                <div class="preview-link"></div>
              </div>
            </div>
            <div class="preview-hero">
              <div class="preview-h1" style={`background: ${e.accent};`}></div>
              <div class="preview-h2" style={`background: ${e.accent}; opacity:0.5;`}></div>
              <div class="preview-cta" style={`background: ${e.accent};`}></div>
            </div>
            <div class="exemple-tag">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="5" fill="#1A3C34"/><path d="M2.5 5l1.5 1.5 3-3" stroke="#FAFAF8" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Livré en 48h
            </div>
          </div>
          <div class="exemple-info">
            <div class="exemple-meta">
              <span class="exemple-secteur">{e.secteur}</span>
              <span class="exemple-ville">{e.ville}</span>
            </div>
            <div class="exemple-titre">{e.titre}</div>
            <div class="exemple-desc">{e.desc}</div>
          </div>
        </div>
      ))}
    </div>

    <div class="exemples-cta">
      <a href="#commander" class="btn-primary">Je veux un site comme ça →</a>
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .section-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--accent-pale);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .section-h2 {
    font-size: clamp(32px, 4vw, 48px);
    color: var(--text-primary);
    margin-bottom: 16px;
    line-height: 1.1;
  }
  .section-h2 em { font-style: italic; color: var(--accent); }
  .section-sub {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
  }
  .exemples-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .exemple-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .exemple-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(14,14,14,0.1);
  }
  .exemple-preview {
    height: 180px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
  }
  .preview-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    border-radius: 6px;
  }
  .preview-logo { width: 40px; height: 8px; border-radius: 3px; }
  .preview-links { display: flex; gap: 6px; margin-left: auto; }
  .preview-link { width: 24px; height: 6px; background: rgba(14,14,14,0.15); border-radius: 3px; }
  .preview-hero { padding: 8px 10px; display: flex; flex-direction: column; gap: 7px; }
  .preview-h1 { height: 14px; width: 70%; border-radius: 4px; opacity: 0.7; }
  .preview-h2 { height: 9px; width: 50%; border-radius: 3px; }
  .preview-cta { height: 22px; width: 80px; border-radius: 5px; }
  .exemple-tag {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--accent);
  }
  .exemple-info { padding: 16px; background: var(--white); }
  .exemple-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .exemple-secteur {
    font-size: 11px;
    font-weight: 500;
    background: var(--accent-pale);
    color: var(--accent);
    padding: 3px 8px;
    border-radius: 100px;
  }
  .exemple-ville {
    font-size: 12px;
    color: var(--text-muted);
  }
  .exemple-titre { font-size: 15px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px; }
  .exemple-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }
  .exemples-cta {
    text-align: center;
    margin-top: 40px;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 500;
    background: var(--accent);
    color: var(--white);
    padding: 14px 28px;
    border-radius: var(--radius-md);
    transition: background 0.15s, transform 0.1s;
  }
  .btn-primary:hover { background: var(--accent-light); transform: translateY(-2px); }
  @media (max-width: 900px) {
    .exemples-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .exemples-grid { grid-template-columns: 1fr; }
  }
</style>
