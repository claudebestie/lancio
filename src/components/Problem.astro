---
---
<section class="problem section-pad">
  <div class="container">
    <div class="problem-grid">
      <div class="problem-col before">
        <div class="col-label before-label">Avant Lancio</div>
        <div class="col-items">
          <div class="col-item">
            <div class="item-icon cross">✕</div>
            <div class="item-text">
              <strong>3 semaines de devis</strong>
              <span>Réunions, cahier des charges, allers-retours sans fin</span>
            </div>
          </div>
          <div class="col-item">
            <div class="item-icon cross">✕</div>
            <div class="item-text">
              <strong>Budget imprévisible</strong>
              <span>€2 000 minimum, jusqu'à €8 000 avec les "extras"</span>
            </div>
          </div>
          <div class="col-item">
            <div class="item-icon cross">✕</div>
            <div class="item-text">
              <strong>Résultat décevant</strong>
              <span>Template générique, pas de SEO, maintenance impossible</span>
            </div>
          </div>
          <div class="col-item">
            <div class="item-icon cross">✕</div>
            <div class="item-text">
              <strong>Délais non tenus</strong>
              <span>Promis en 2 semaines, livré en 2 mois</span>
            </div>
          </div>
        </div>
      </div>

      <div class="problem-divider">
        <div class="divider-line"></div>
        <div class="divider-badge">vs</div>
        <div class="divider-line"></div>
      </div>

      <div class="problem-col after">
        <div class="col-label after-label">Avec Lancio</div>
        <div class="col-items">
          <div class="col-item">
            <div class="item-icon check">✓</div>
            <div class="item-text">
              <strong>Commande en 5 minutes</strong>
              <span>En ligne, sans rendez-vous. On s'occupe du reste.</span>
            </div>
          </div>
          <div class="col-item">
            <div class="item-icon check">✓</div>
            <div class="item-text">
              <strong>€650 tout compris</strong>
              <span>Prix fixe, affiché, sans surprise. Add-ons optionnels.</span>
            </div>
          </div>
          <div class="col-item">
            <div class="item-icon check">✓</div>
            <div class="item-text">
              <strong>Site pro sur mesure</strong>
              <span>Design personnalisé, optimisé SEO, mobile-first</span>
            </div>
          </div>
          <div class="col-item">
            <div class="item-icon check">✓</div>
            <div class="item-text">
              <strong>En ligne en 48h</strong>
              <span>Garanti. Vous commandez lundi, en ligne mercredi.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-pad { padding: var(--section-py) 0; }
  .problem-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: start;
  }
  .problem-col { padding: 0 32px; }
  .col-label {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
    display: inline-block;
    padding: 5px 12px;
    border-radius: 100px;
  }
  .before-label { background: #FEF0F0; color: #A32D2D; border: 1px solid rgba(163,45,45,0.15); }
  .after-label { background: var(--accent-pale); color: var(--accent); border: 1px solid rgba(26,60,52,0.15); }
  .col-items { display: flex; flex-direction: column; gap: 20px; }
  .col-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .item-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .item-icon.cross { background: #FEF0F0; color: #A32D2D; }
  .item-icon.check { background: var(--accent-pale); color: var(--accent); }
  .item-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .item-text strong { font-size: 14px; font-weight: 500; color: var(--text-primary); }
  .item-text span { font-size: 13px; color: var(--text-secondary); line-height: 1.7; }
  .problem-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding-top: 40px;
  }
  .divider-line {
    width: 1px;
    height: 80px;
    background: var(--border);
  }
  .divider-badge {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .problem-grid { grid-template-columns: 1fr; gap: 32px; }
    .problem-col { padding: 0; }
    .problem-divider { flex-direction: row; padding-top: 0; }
    .divider-line { width: 80px; height: 1px; }
  }
</style>
